<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        a{
            position:fixed;
            left: 100px;
            top:100px;
        }
         b{
            position:static;
            left: 400px;
            top:400px;
        }
         c{
            position:sticky;
            left: 800px;
            top:400px;
        }
         d{
            position:relative;
            left: 100px;
            top:100px;
        }
         e{
            position:absolute;
            left: 400px;
            top:400px;
        }
    </style>

</head>
<body>
    <a>hello world! ---a</a>
    <b>hello world! ---b</b>
    <c>hello world! ---c</c>
    <d>hello world! ---d</d>
    <e>hello world! ---e</e>
</body>
</html>



